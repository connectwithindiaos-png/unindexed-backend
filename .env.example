PORT=5000
NODE_ENV=production

# Database
DATABASE_URL=postgresql://user:password@host:5432/devicemanagement

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://your-frontend.vercel.app

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
